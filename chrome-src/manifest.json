{
  "manifest_version": 3,
  "name": "Docs Tools",
  "version": "1.6",
  "description": "Open docs sites from clipboard and GitHub source from current page.",
  "permissions": ["tabs"],
  "host_permissions": [
    "https://docs.kore.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}